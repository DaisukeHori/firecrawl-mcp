# ============================================
# Firecrawl MCP Server - 環境変数設定
# ============================================

# ── Firecrawl インスタンス（必須）──
# セルフホスト Firecrawl の URL
FIRECRAWL_API_URL=https://firecrawl.appserver.tokyo

# Firecrawl API キー（セルフホストの場合は認証不要なら空でもOK）
FIRECRAWL_API_KEY=fc-test

# ── MCP サーバー認証（必須）──
# Claude.ai からのアクセスを制限するための API キー
# ?key=<MCP_API_KEY> で渡す
MCP_API_KEY=your-secret-api-key-here
